# ============================================================
# ClaimCheck Daily — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Anthropic (Claude Researcher)
# ----------------------------------------------------------
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...


# ----------------------------------------------------------
# OpenAI (GPT Director)
# ----------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model used by the Director agent (optional override)
# OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------
# GitHub (optional — for Actions authentication / Git push)
# ----------------------------------------------------------
# Set automatically by GitHub Actions via secrets.GITHUB_TOKEN
# Only needed for local publishing via git push
# GITHUB_TOKEN=ghp_...

# ----------------------------------------------------------
# Serper (Google web search — optional but strongly recommended)
# ----------------------------------------------------------
# Enables web_search for the Researcher so Claude can discover
# authoritative URLs instead of guessing them from training knowledge.
# Free tier: 2,500 queries, no credit card required.
# Get a key at: https://serper.dev
# Without this key the Researcher falls back to fetch_url with
# inferred URLs (same behaviour as before web_search was added).
# SERPER_API_KEY=...
# SERPER_SEARCH_COUNT=5     # results per search call (default: 5)

# ----------------------------------------------------------
# Pipeline tuning (all optional)
# ----------------------------------------------------------
# LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
# MAX_CLAIMS_PER_DAY=5
# RESEARCH_WORKERS=3

# ----------------------------------------------------------
# Researcher tuning (all optional)
# ----------------------------------------------------------
# ANTHROPIC_MODEL=claude-opus-4-5-20251101   # model for the Researcher
# CLAUDE_MAX_TOKENS=10000                    # max tokens per research call
# CLAUDE_THINKING_BUDGET=3000               # extended thinking budget (must be < CLAUDE_MAX_TOKENS)

# ----------------------------------------------------------
# HTTP / fetch tuning (all optional)
# ----------------------------------------------------------
# HTTP_TIMEOUT=15           # per-request timeout in seconds (default: 15)
# MAX_CONTENT_CHARS=4000    # max chars of page text returned to Claude (default: 4000)
# FEED_TIMEOUT=10           # RSS feed fetch timeout in seconds
